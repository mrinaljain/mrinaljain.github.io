  "apiEndpoints": {
    "getForPage": "GET /api/popups?page=/",
    "create": "POST /api/popups",
    "getById": "GET /api/popups/{id}",
    "updateById": "PUT /api/popups/{id}",
    "deleteById": "DELETE /api/popups/{id}",
    "trackAnalytics": "POST /api/popups/{id}/analytics"
  },
  "displayFrequencies": {
    "once": "Shows once per browser (remembers dismissal)",
    "always": "Shows every time user visits",
    "session": "Shows once per browser session (clears on tab close)"
  },
  "buttonActionTypes": {
    "link": "Opens URL in target (_blank or _self)",
    "modal": "Opens a modal (extendable)",
    "custom": "Custom action (extendable)"
  },
  "videoProviders": {
    "youtube": "YouTube embedded videos",
    "vimeo": "Vimeo embedded videos",
